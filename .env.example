# ============================================
# InTrack — приклад конфігурації (скопіюйте у .env і адаптуйте)
# ============================================

# Backend
NODE_ENV=production
PORT=5000

# Frontend (Vite; порожнє = відносний /api через nginx-проксі)
VITE_API_URL=

# Database (має збігатися з docker-compose.yml)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=intrack_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=intrack-dev-jwt-secret-change-me
JWT_EXPIRES_IN=24h

# CORS
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Тоглі безпеки (вмикаються на Етапі 3 «Секюр»)
ENABLE_BCRYPT=false
ENABLE_TLS=false
ENABLE_MFA=false
ENABLE_BACKUP=false
BACKUP_SCHEDULE="0 2 * * *"

# Redis (Етап 2)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
